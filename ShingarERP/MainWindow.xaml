<Window x:Class="ShingarERP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShingarERP"
        xmlns:inv="clr-namespace:ShingarERP.UI.Views.Inventory"
        xmlns:cust="clr-namespace:ShingarERP.UI.Views.Customer"
        xmlns:acct="clr-namespace:ShingarERP.UI.Views.Accounting"
        mc:Ignorable="d"
        Title="Shringar Jewellers ERP – Phase 1"
        Height="780" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Navigation sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Content area -->
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar navigation ──────────────────────────────────── -->
        <Border Grid.Column="0" Background="#1F4975">
            <DockPanel>
                <!-- Logo / App name -->
                <Border DockPanel.Dock="Top" Padding="16,20" BorderBrush="#2A5FA0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="💎 Shringar" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Jewellers ERP" FontSize="13" Foreground="#90CAF9"/>
                        <TextBlock Text="v1.0 – Phase 1" FontSize="10" Foreground="#64B5F6" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <TextBlock Text="INVENTORY" FontSize="10" Foreground="#64B5F6" FontWeight="Bold"
                               Margin="16,0,0,4"/>

                    <Button Content="🥇  Metal Inventory" Tag="MetalInventory"
                            Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                    <Button Content="💍  Finished Goods"  Tag="FinishedGoods"
                            Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>

                    <TextBlock Text="CUSTOMER" FontSize="10" Foreground="#64B5F6" FontWeight="Bold"
                               Margin="16,12,0,4"/>
                    <Button Content="👤  Customer Master"  Tag="CustomerMaster"
                            Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>

                    <TextBlock Text="ACCOUNTS" FontSize="10" Foreground="#64B5F6" FontWeight="Bold"
                               Margin="16,12,0,4"/>
                    <Button Content="📒  Ledger"            Tag="Ledger"
                            Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                    <Button Content="📋  Chart of Accounts" Tag="AccountChart"
                            Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                </StackPanel>

                <!-- Version footer -->
                <TextBlock DockPanel.Dock="Bottom" Text="Shringar ERP © 2024"
                           FontSize="10" Foreground="#546E8A" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            </DockPanel>
        </Border>

        <!-- ── Content frame ───────────────────────────────────────── -->
        <Frame Grid.Column="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
